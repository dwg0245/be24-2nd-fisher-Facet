pipeline {
  agent {
    kubernetes {
      label "node-kaniko-${UUID.randomUUID().toString()}"
      defaultContainer 'node'
      yaml """
apiVersion: v1
kind: Pod
spec:
  restartPolicy: Never
  containers:
    - name: node
      image: node:22.17.1-bullseye
      command: ['cat']
      tty: true
      resources:
        requests:
          memory: "512Mi"
          cpu: "200m"
        limits:
          memory: "1Gi"
          cpu: "500m"
      volumeMounts:             
        - name: workspace       
          mountPath: /workspace 
    - name: kubectl
      image: bitnami/kubectl:latest  # kubectl이 설치된 가벼운 이미지
      command: ['cat']
      tty: true
      resources:
        requests:
          memory: "128Mi"
          cpu: "100m"
        limits:
          memory: "256Mi"
          cpu: "200m"
      volumeMounts:
        - name: workspace         # 프로젝트 공유 공간
          mountPath: /workspace

    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['/busybox/sh','-c','sleep infinity']
      tty: true
      resources:
        requests:
          memory: "1Gi"  # Kaniko는 빌드 시 메모리를 많이 먹습니다.
          cpu: "500m"
        limits:
          memory: "1.2Gi"
          cpu: "1000m"
      volumeMounts:
        - name: docker-config
          mountPath: /kaniko/.docker
        - name: workspace
          mountPath: /workspace
      
  volumes:
    - name: workspace
      emptyDir: {}
    - name: docker-config
      secret:
        secretName: dockerhub-front
        items:
          - key: .dockerconfigjson
            path: config.json
"""
    }
  }

  environment {
    IMAGE_NAME = 'dwg0245/front_facet'
    IMAGE_TAG  = "${env.BUILD_NUMBER}"
    NAMESPACE = "default"
  }
  stages {
    stage('Checkout') {
      steps {
        container('node') {
          checkout([$class: 'GitSCM',
            branches: [[name: '*/main']],
            userRemoteConfigs: [[url: 'https://github.com/dwg0245/be24-2nd-fisher-Facet']]
          ])
        }
      }
    }

    stage('Gradle Build') {
      steps {
        container('node') {
          sh '''
            cd vue
            npm i
            npm run build
          '''
        }
      }
    }

    stage('Kaniko Build & Push') {
      steps {
        container('kaniko') {
          sh """
            /kaniko/executor \
              --context=${WORKSPACE}/vue \
              --dockerfile=${WORKSPACE}/vue/Dockerfile \
              --destination=${IMAGE_NAME}:${IMAGE_TAG} \
              --destination=${IMAGE_NAME}:latest \
              --single-snapshot \
              --use-new-run \
              --cache=true \
              --snapshotMode=redo
          """
        }
      }
    }

    stage('Result') {
      steps {
        echo "Pushed: ${IMAGE_NAME}:${IMAGE_TAG}"
      }
    }


    stage('Blue-Green Deployment') {
            steps {
                container('kubectl') {
                    script {
                        sh "sleep 15"

                        // 홀수/짝수 판별
                        def isEven = (IMAGE_TAG.toInteger() % 2 == 0)
                        def targetColor = isEven ? "green" : "blue"
                        def idleColor = isEven ? "blue" : "green"
                        
                        echo "현재 빌드 번호: ${env.BUILD_NUMBER} -> 배포 대상: ${targetColor.toUpperCase()}"

                        // 1. 새로운 버전 Deployment 생성/업데이트
                        sh """
cat <<EOF | kubectl apply -f -
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-deployment-${targetColor}
  labels:
    type: frontend
    version: ${targetColor}
spec:
  replicas: 1
  selector:
    matchLabels:
      type: frontend
  strategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        type: frontend
        version: ${targetColor}
    spec:
      containers:
        - name: frontend
          image: ${IMAGE_NAME}:${IMAGE_TAG}
          imagePullPolicy: Always
          ports:
            - containerPort: 80
          envFrom:
            - configMapRef:
                name: env-config
EOF
                        """

                        // 2. 배포 완료 대기
                        sh "kubectl rollout status deployment/frontend-deployment-${targetColor} -n ${NAMESPACE}"

                        // 3. Service 가리키는 방향 전환 (Switching)
                        sh """
cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Service
metadata:
  name: frontend-service
spec:
  type: LoadBalancer
  selector:
    app: frontend          
    version: ${targetColor}
  ports:
    - name: http
      port: 80              
      targetPort: 80    
EOF
                        """

                        // 4. 이전 버전 Deployment Scale Down (리소스 절약)
                        echo "이전 버전(${idleColor})을 정리합니다."
                        sh "kubectl scale deployment frontend-deployment-${idleColor} --replicas=0 -n ${NAMESPACE} || true"
                    }
                }
            }
        }
    
  }
}

